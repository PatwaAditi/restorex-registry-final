rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.uid == "vMTtBJXYYCgPCpzhutqxGcflffC3" ||
         request.auth.uid == "LR3UjgNpG8YIY41zuxVBwTcDAO52" ||
         (request.auth.token.email == "work.aditipatwa@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "moes.official@registry.gov") ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'official', 'government']));
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
             request.resource.data.uid == resource.data.uid;
    }

    function roleNotModified() {
      return !('role' in request.resource.data) ||
             request.resource.data.role == resource.data.role;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return data.uid is string && 
             data.displayName is string && 
             data.role in ['user', 'admin', 'guest', 'official', 'government'];
    }

    function isValidUserPrivate(data) {
      return data.email is string &&
             (!('age' in data) || data.age is number) &&
             (!('gender' in data) || data.gender is string) &&
             (!('mobileNo' in data) || data.mobileNo is string);
    }

    function isValidSubmission(data) {
      return data.userId is string &&
             data.imageUrl is string &&
             data.latitude is number &&
             data.longitude is number &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidWithdrawal(data) {
      return data.userId is string &&
             data.creditsRequested is number &&
             data.amountINR is number &&
             data.status in ['pending', 'paid', 'rejected'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && isOwner(userId);
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isAdmin() || (isOwner(userId) && uidNotModified() && roleNotModified()));
    }

    match /users_private/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUserPrivate(request.resource.data) && isOwner(userId);
      allow update: if isAuthenticated() && isValidUserPrivate(request.resource.data) && 
                    (isAdmin() || isOwner(userId));
    }

    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      // Lock if approved. Allow admin to review. Allow owner to resubmit if rejected.
      allow update: if (isAdmin() && resource.data.status != 'approved') || 
                    (isOwner(resource.data.userId) && resource.data.status == 'rejected' && request.resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /verified_projects/{projectId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['blockchainStatus', 'blockchainTxHash']);
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (resource == null || isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      // Allow users to enroll
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledUsers']) &&
                    request.resource.data.enrolledUsers.size() <= resource.data.volunteerLimit;
    }

    match /wallets/{walletId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
  }
}
